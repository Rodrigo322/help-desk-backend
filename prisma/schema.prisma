generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  PENDING
  ON_HOLD
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationEventType {
  CREATED
  ASSIGNED
  UPDATED
}

enum TicketAuditLogAction {
  STATUS_CHANGED
  ASSIGNED
  PRIORITY_CHANGED
}

model User {
  id                 String         @id @default(uuid())
  name               String
  email              String         @unique
  password           String
  departmentId       String
  role               UserRole       @default(EMPLOYEE)
  isActive           Boolean        @default(true)
  department         Department     @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  tickets            Ticket[]       @relation("TicketCreatedBy")
  assignedTickets    Ticket[]       @relation("TicketAssignedTo")
  closedTickets      Ticket[]       @relation("TicketClosedBy")
  comments           Comment[]
  ticketAuditLogs    TicketAuditLog[]
  managedDepartments Department[]   @relation("DepartmentManager")
  notifications      Notification[] @relation("NotificationRecipient")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([departmentId])
  @@index([role])
  @@index([isActive])
}

model Department {
  id               String   @id @default(uuid())
  name             String   @unique
  managerUserId    String?
  isActive         Boolean  @default(true)
  manager          User?    @relation("DepartmentManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  users            User[]
  originTickets    Ticket[] @relation("TicketOriginDepartment")
  targetTickets    Ticket[] @relation("TicketTargetDepartment")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([managerUserId])
  @@index([isActive])
}

model Ticket {
  id                 String         @id @default(uuid())
  title              String
  description        String
  status             TicketStatus   @default(NEW)
  priority           TicketPriority @default(MEDIUM)
  createdByUserId    String
  originDepartmentId String
  targetDepartmentId String
  assignedToUserId   String?
  closedByUserId     String?
  firstResponseAt    DateTime?
  resolvedAt         DateTime?
  firstResponseDeadlineAt DateTime?
  resolutionDeadlineAt    DateTime?
  createdByUser      User           @relation("TicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  originDepartment   Department     @relation("TicketOriginDepartment", fields: [originDepartmentId], references: [id], onDelete: Restrict)
  targetDepartment   Department     @relation("TicketTargetDepartment", fields: [targetDepartmentId], references: [id], onDelete: Restrict)
  assignedToUser     User?          @relation("TicketAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  closedByUser       User?          @relation("TicketClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  comments           Comment[]
  attachments        Attachment[]
  notifications      Notification[]
  auditLogs          TicketAuditLog[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([createdByUserId])
  @@index([originDepartmentId])
  @@index([targetDepartmentId])
  @@index([assignedToUserId])
  @@index([closedByUserId])
  @@index([status])
  @@index([priority])
  @@index([firstResponseDeadlineAt])
  @@index([resolutionDeadlineAt])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  isInternal Boolean @default(false)
  ticketId  String
  userId    String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@index([userId])
  @@index([isInternal])
}

model Attachment {
  id        String   @id @default(uuid())
  fileName  String
  fileUrl   String
  mimeType  String
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
}

model Notification {
  id              String   @id @default(uuid())
  message         String
  eventType       NotificationEventType
  recipientUserId String
  ticketId        String?
  readAt          DateTime?
  recipientUser   User     @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  ticket          Ticket?  @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([recipientUserId])
  @@index([ticketId])
  @@index([readAt])
  @@index([eventType])
}

model TicketAuditLog {
  id          String             @id @default(uuid())
  ticketId    String
  actorUserId String
  action      TicketAuditLogAction
  fromValue   String?
  toValue     String?
  metadata    Json?
  ticket      Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actorUser   User               @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([ticketId])
  @@index([actorUserId])
  @@index([action])
}
