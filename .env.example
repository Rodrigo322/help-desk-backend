NODE_ENV=development
PORT=3333

# Runtime pooled connection (Neon pooler / pgbouncer)
DATABASE_URL="postgresql://<user>:<password>@<pooled-host>/<database>?sslmode=require&pgbouncer=true"

# Direct connection for Prisma Migrate/CLI
DIRECT_URL="postgresql://<user>:<password>@<direct-host>/<database>?sslmode=require"

# Optional local-only shadow database for Prisma Migrate diff/dev workflows
SHADOW_DATABASE_URL="postgresql://<user>:<password>@<shadow-host>/<shadow-database>?sslmode=require"

# Comma-separated list for explicit origins. Use * only when appropriate.
CORS_ORIGIN="http://localhost:5173"

JWT_SECRET="change-this-secret"

MASTER_NAME="Master Admin"
MASTER_EMAIL="master@local.dev"
MASTER_PASSWORD="Master@123456"
MASTER_ROLE="ADMIN"
MASTER_DEPARTMENT="Operations"

# Legacy aliases (optional, kept for compatibility)
ADMIN_NAME="Master Admin"
ADMIN_EMAIL="master@local.dev"
ADMIN_PASSWORD="Master@123456"
ADMIN_ROLE="ADMIN"
ADMIN_DEPARTMENT="Operations"
